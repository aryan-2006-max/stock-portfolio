PORT=5000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=stock_portfolio

# JWT — change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_me

# Alpha Vantage (optional) — free key at https://www.alphavantage.co/support/#api-key
# Leave as "demo" to use seeded DB prices instead
ALPHA_VANTAGE_API_KEY=demo

# Frontend URL (for CORS — set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000
